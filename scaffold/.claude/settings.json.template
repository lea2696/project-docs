{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "node {{PROJECT_DOCS_PATH}}/scripts/validate-docs.mjs --strict",
            "timeout": 30,
            "statusMessage": "Validating documentation..."
          }
        ]
      }
    ]
  }
}
