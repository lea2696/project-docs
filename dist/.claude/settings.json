{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "node scripts/docs/validate-docs.mjs --strict",
            "timeout": 30,
            "statusMessage": "Validating documentation..."
          }
        ]
      }
    ]
  }
}
